{
  "entryPoints": ["src/index.ts", "src/types.ts", "src/system.ts", "src/core.ts"],
  "out": "docs",
  "tsconfig": "tsconfig.doc.json",
  "plugin": [],
  "excludePrivate": true,
  "excludeProtected": false,
